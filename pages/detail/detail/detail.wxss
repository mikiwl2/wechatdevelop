.page {
  min-height: 100%;
  background: var(--color-bg);
}

.hero {
  position: relative;
  height: 520rpx;
  overflow: hidden;
  background: #000;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.55) 100%);
}

.hero-actions {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  gap: 16rpx;
}

.pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10px);
  color: #fff;
}

.pill-icon {
  font-size: 34rpx;
}

.pill-text {
  font-size: 28rpx;
  font-weight: 600;
}

.active-like {
  background: rgba(236, 72, 153, 0.28);
}

.active-save {
  background: rgba(99, 102, 241, 0.28);
}

.content {
  padding: 24rpx var(--spacing-page) 0;
}

.meta {
  margin: 12rpx 0 24rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 6rpx;
}

.sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 12rpx 0 16rpx;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.comment-count {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.c-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-border);
}

.c-body {
  flex: 1;
  min-width: 0;
}

.c-top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.c-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.c-time {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.c-text {
  font-size: 28rpx;
  color: var(--color-text);
  word-break: break-all;
}

.comment-empty {
  padding: 60rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-hint);
}

.bottom-spacer {
  height: 140rpx;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx var(--spacing-page);
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--color-border);
  display: flex;
  gap: 16rpx;
  z-index: 100;
}

.input {
  flex: 1;
  height: 76rpx;
  background: var(--color-bg);
  border-radius: 999rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.send {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
  color: #fff;
  font-weight: 600;
}
